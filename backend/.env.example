PORT=4000

# Opcional: use em deploy quando os arquivos precisam gerar URL publica absoluta.
# PUBLIC_BASE_URL=https://seu-backend.exemplo.com

# Opcional: restrinja origens no deploy, separadas por virgula.
# CORS_ORIGIN=https://seu-frontend.exemplo.com

# Dados locais. Em producao, prefira volume persistente ou banco Postgres/Supabase.
# DATA_DIR=/var/lib/mg-autocenter/data
# UPLOADS_DIR=/var/lib/mg-autocenter/uploads

LOCAL_USER_NAME=MG Auto
LOCAL_USER_EMAIL=local@mgauto.local

# Banco em producao. Se DATABASE_URL nao existir, o backend usa JSON local.
# DATABASE_URL=postgresql://usuario:senha@host:5432/banco
# PGSSL=true

# Focus NFe
# Tambem podem ser salvos na entidade Configuracao pelo painel:
# focusnfe_api_key_producao, focusnfe_api_key_homologacao, cnpj,
# inscricao_estadual, inscricao_municipal, cod_municipio, nfe_serie,
# nfce_serie, nfse_serie_dps.
# FOCUSNFE_API_KEY=
# FOCUSNFE_API_KEY_HOMOLOGACAO=
# CNPJ_EMITENTE=
# INSCRICAO_ESTADUAL=
# INSCRICAO_MUNICIPAL=
# COD_MUNICIPIO=

# Asaas
# Tambem pode ser salvo como Configuracao: asaas_api_key
# ASAAS_API_KEY=
